# Sanity — manage at https://www.sanity.io/manage/project/3h85v8ma
# Project ID and dataset are public identifiers (shipped in the client bundle),
# safe to commit here as defaults.
NEXT_PUBLIC_SANITY_PROJECT_ID=3h85v8ma
NEXT_PUBLIC_SANITY_DATASET=production
# API version, date-pinned.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token — only needed for draft/preview reads. The production dataset is
# public, so published content reads without it. Viewer permission:
# manage.sanity.io > API > Tokens.
SANITY_API_READ_TOKEN=

# Shared secret for the future /api/revalidate webhook (set the same value in
# manage.sanity.io > API > Webhooks). Not wired yet — reserved for a later phase.
SANITY_REVALIDATE_SECRET=
